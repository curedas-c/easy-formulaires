{
  "name": "easyFormulaire",
  "description": "An Ionic project",
  "version": "2.6.0",
  "appCodeVersion": 100,
  "author": "Curedas Codjo",
  "homepage": "https://curedas-c.github.io/",
  "scripts": {
    "start": "ionic cap run android -l --external",
    "build": "ionic cap build android --prod && npm run post-build",
