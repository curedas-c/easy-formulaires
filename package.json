    "post-build": "node ./build/post-build.js",
    "commit": "git-cz && npm run update:version",
    "update:version": "npm run versioning && standard-version",
    "versioning": "node ./build/build-pre.js"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "private": true,
